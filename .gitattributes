# Shell scripts must keep LF endings — CRLF breaks the shebang inside the
# Linux container when the working tree is synced to the Pi.
* text=auto
*.sh text eol=lf
Dockerfile text eol=lf
# Frontend assets keep LF too: Biome formats with LF, and mixed endings
# would churn diffs between the Windows dev machine and the Pi.
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
